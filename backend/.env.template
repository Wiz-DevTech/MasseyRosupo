# ── M&R Backend environment ──────────────────────────────────────────────────
# Copy to .env and fill in. All values have safe defaults for local dev.

# Public base URL of THIS backend (used in CORS + KC redirect_uri).
MR_BACKEND_URL=http://localhost:3009

# Keycloak (CipherNex hub realm — shared across all entities)
KC_URL=http://keycloak-ciphernex:8080
KC_REALM=ciphernex
# Trustee portal client
KC_CLIENT_TRUSTEE=massey-admin
KC_REQUIRED_ROLE_TRUSTEE=trustee
# Client portal (beneficiaries) client
KC_CLIENT_CLIENT=massey-client
KC_REQUIRED_ROLE_CLIENT=beneficiary
# Where Keycloak bounces back after login (must match KC client redirect_uri)
KC_REDIRECT_TRUSTEE=https://masseyrosupo.com/admin-portal.html
KC_REDIRECT_CLIENT=https://masseyrosupo.com/portal-login.html

# Upstream wisdomignited backend (Operations & Arbitration APIs live here)
WISDOM_BACKEND_URL=https://wisdomignited.com
WISDOM_BACKEND_API=https://wisdomignited.com/api

# Local JWT secret for session tokens (only used for non-KC fallback)
JWT_SECRET=change-me-in-prod-masseyrosupo
SESSION_HOURS=24

# Port this service listens on
PORT=3009
